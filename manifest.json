{
  "manifest_version": 3,
  "name": "AI Site Wrapper",
  "version": "1.0.0",
  "description": "Aggregate AI chat websites into one window",
  "permissions": [
    "storage",
    "tabs",
    "browsingData",
    "scripting",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "AI Site Wrapper"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "app/error.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
